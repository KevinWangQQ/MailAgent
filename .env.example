# MailAgent 环境变量配置
# 复制此文件为 .env 并填入你的配置

# =============================================================================
# Notion 配置 (必填)
# =============================================================================
NOTION_TOKEN=ntn_your_token_here
EMAIL_DATABASE_ID=your_email_database_id
CALENDAR_DATABASE_ID=your_calendar_database_id

# =============================================================================
# Mail.app 配置 (必填)
# =============================================================================
USER_EMAIL=your.email@example.com
MAIL_ACCOUNT_NAME=Exchange
MAIL_INBOX_NAME=收件箱
MAIL_SENT_NAME=已发送邮件

# =============================================================================
# 邮件同步配置
# =============================================================================
# 同步起始日期 (只同步此日期之后的邮件到 Notion)
SYNC_START_DATE=2026-01-01

# 要同步的邮箱列表（逗号分隔）
SYNC_MAILBOXES=收件箱,发件箱

# 雷达轮询间隔 (秒)，检测新邮件
RADAR_POLL_INTERVAL=5

# 健康检查间隔 (秒)
HEALTH_CHECK_INTERVAL=3600

# =============================================================================
# AppleScript 配置
# =============================================================================
# 每批获取邮件数量（初始化同步用，建议 10-50）
INIT_BATCH_SIZE=10

# AppleScript 超时时间（秒）
APPLESCRIPT_TIMEOUT=200

# =============================================================================
# 日历同步配置 (可选，calendar_main.py 使用)
# =============================================================================
CALENDAR_NAME=日历
CALENDAR_SYNC_MODE=eventkit
CALENDAR_PAST_DAYS=7
CALENDAR_FUTURE_DAYS=15

# =============================================================================
# 飞书通知配置 (可选)
# =============================================================================
# FEISHU_APP_ID=your_app_id
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=your_chat_id
# FEISHU_WEBHOOK_URL=
# FEISHU_WEBHOOK_SECRET=
# FEISHU_NOTIFY_ENABLED=false

# =============================================================================
# Redis 事件消费配置 (可选，启用 Notion→Mail 反向事件驱动)
# =============================================================================
# REDIS_URL=redis://localhost:6379
# REDIS_DB=2
# REDIS_EVENTS_ENABLED=false

# =============================================================================
# 看板统计上报配置 (可选，启用远程监控看板)
# =============================================================================
# STATS_REPORT_URL=https://mailagent.chenge.ink/api/stats/report
# STATS_REPORT_INTERVAL=60
# STATS_REPORT_TOKEN=your_webhook_secret_here

# =============================================================================
# 其他配置
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/sync.log
SYNC_STORE_DB_PATH=data/sync_store.db
MAX_ATTACHMENT_SIZE=20971520
